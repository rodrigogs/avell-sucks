<UserControl x:Class="AvellSucks.UI.Views.FanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:AvellSucks.UI.Controls"
             xmlns:loc="clr-namespace:AvellSucks.UI.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Mode selector -->
            <Border Style="{StaticResource Panel}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Tr Common.PerformanceMode}" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource SegmentBar}" Margin="0,10,0,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" x:Name="ModeBar">
                            <RadioButton x:Name="ModeAuto" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Common.Auto}" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeBoost" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Common.Boost}" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeCustom" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Common.Custom}" Checked="OnModeChecked"/>
                            <Rectangle Width="1" Fill="{StaticResource Hairline}" Margin="6,6"/>
                            <RadioButton x:Name="ModeL1" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="L1" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeL2" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="L2" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeL3" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="L3" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeL4" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="L4" Checked="OnModeChecked"/>
                            <RadioButton x:Name="ModeL5" GroupName="fanmode" Style="{StaticResource SegmentToggle}" Content="L5" Checked="OnModeChecked"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="ModeHint" Style="{StaticResource Caption}" Margin="2,10,0,0"
                               Text="{loc:Tr Fan.Hint.Default}"/>
                </StackPanel>
            </Border>

            <!-- Thermal response: temp→PWM curve with the live thermal layer behind
                 it (60 s residency histogram + current operating point). Temperature
                 is the X axis, so the thermal layer aligns exactly with the curve. -->
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{loc:Tr Fan.ThermalResponse}" Style="{StaticResource SectionLabel}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Magenta}" VerticalAlignment="Center"/>
                            <TextBlock Text="CPU" Margin="5,0,14,0" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Cyan}" VerticalAlignment="Center"/>
                            <TextBlock Text="GPU" Margin="5,0,0,0" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="{loc:Tr Fan.CurveCaption}"
                               Style="{StaticResource Caption}" Margin="0,3,0,0"/>
                    <ctl:FanCurveEditor x:Name="Curve" Height="260" Margin="0,12,0,0"/>
                    <!-- Live: dragging a point re-applies the curve on settle.
                         "Reset to auto" is the one explicit escape hatch. -->
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                   Style="{StaticResource Caption}"
                                   Text="{loc:Tr Fan.ChangesApply}"/>
                        <Button x:Name="ResetBtn" Content="{loc:Tr Fan.ResetToAuto}" Style="{StaticResource SecondaryButton}"
                                DockPanel.Dock="Right" HorizontalAlignment="Right" Click="OnReset"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Write-gate notice -->
            <Border x:Name="GateNotice" Style="{StaticResource Panel}" Margin="0,16,0,0"
                    Background="{StaticResource WarnTint}" BorderBrush="{StaticResource Warn}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="{StaticResource Warn}" VerticalAlignment="Center"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Ink}"
                               TextWrapping="Wrap" Text="{loc:Tr Fan.Gate}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
