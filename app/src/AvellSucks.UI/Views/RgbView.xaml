<UserControl x:Class="AvellSucks.UI.Views.RgbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:AvellSucks.UI.Controls"
             xmlns:loc="clr-namespace:AvellSucks.UI.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Keyboard preview -->
            <Border Style="{StaticResource Panel}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Tr Rgb.Preview}" Style="{StaticResource SectionLabel}"/>
                    <ctl:KeyboardPreview x:Name="Keyboard" Height="150" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Color -->
                <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Rgb.Color}" Style="{StaticResource SectionLabel}"/>
                        <ctl:HsvPicker x:Name="Picker" Height="180" Margin="0,10,0,0"/>
                        <DockPanel Margin="0,12,0,0">
                            <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="{StaticResource RadiusSm}"
                                    x:Name="Swatch" Background="{StaticResource Magenta}" BorderBrush="{StaticResource Hairline}" BorderThickness="1"/>
                            <TextBox x:Name="HexInput" Style="{StaticResource MonoInput}" Margin="10,0,0,0"
                                     Text="#FF2E88" VerticalContentAlignment="Center"
                                     KeyDown="OnHexKey" LostFocus="OnHexCommit"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Effect + params -->
                <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Rgb.Effect}" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource SegmentBar}" Margin="0,10,0,0">
                            <UniformGrid Columns="5" x:Name="EffectBar">
                                <RadioButton x:Name="FxStatic" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Fx.Static}" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxBreathing" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Fx.Breathe}" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxCycle" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Fx.Cycle}" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxWave" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Fx.Wave}" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxRipple" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Fx.Ripple}" Checked="OnEffectChecked"/>
                            </UniformGrid>
                        </Border>

                        <TextBlock Text="{loc:Tr Rgb.Brightness}" Style="{StaticResource FieldLabel}" Margin="2,18,0,0"/>
                        <Slider x:Name="BrightnessSlider" Style="{StaticResource NeonSlider}" Minimum="0" Maximum="100"
                                Value="100" Margin="0,6,0,0" ValueChanged="OnBrightnessChanged"/>

                        <TextBlock Text="{loc:Tr Rgb.Speed}" Style="{StaticResource FieldLabel}" Margin="2,14,0,0"/>
                        <Border Style="{StaticResource SegmentBar}" Margin="0,6,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" x:Name="SpeedBar">
                                <RadioButton x:Name="SpeedSlow" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Speed.Slow}" Checked="OnSpeedChecked"/>
                                <RadioButton x:Name="SpeedNormal" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Speed.Normal}" IsChecked="True" Checked="OnSpeedChecked"/>
                                <RadioButton x:Name="SpeedFast" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="{loc:Tr Rgb.Speed.Fast}" Checked="OnSpeedChecked"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Live: color, effect, speed and brightness apply as you change them. -->
            <TextBlock Style="{StaticResource Caption}" Margin="2,16,0,0"
                       Text="{loc:Tr Rgb.ChangesApply}"/>

            <Border x:Name="DeviceNotice" Style="{StaticResource Panel}" Margin="0,16,0,0"
                    Background="{StaticResource WarnTint}" BorderBrush="{StaticResource Warn}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="{StaticResource Warn}" VerticalAlignment="Center"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Ink}"
                               TextWrapping="Wrap" Text="{loc:Tr Rgb.Device}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
