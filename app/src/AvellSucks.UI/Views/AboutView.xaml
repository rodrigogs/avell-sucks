<UserControl x:Class="AvellSucks.UI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AvellSucks.UI.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Wordmark -->
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource NeonAxis}"
                                Effect="{StaticResource GlowMagenta}" VerticalAlignment="Center">
                            <TextBlock Text="&#xEC4A;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="#FF16060F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Avell" Style="{StaticResource H1}"/>
                                <TextBlock Text="Sucks" Style="{StaticResource H1}" Foreground="{StaticResource Magenta}"/>
                            </StackPanel>
                            <TextBlock Text="{loc:Tr About.Tagline}"
                                       Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- The story -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <!-- Panel fills the width like every other tab; the prose is capped
                     at a readable line length and left-aligned inside it. -->
                <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                    <TextBlock Text="{loc:Tr About.WhyTitle}" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0" Text="{loc:Tr About.Why.P1}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0" Text="{loc:Tr About.Why.P2}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0" Text="{loc:Tr About.Why.P3}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,14,0,0" Text="{loc:Tr About.Why.P4}"/>
                </StackPanel>
            </Border>

            <!-- How it works (brief) -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                    <TextBlock Text="{loc:Tr About.HowTitle}" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0" Text="{loc:Tr About.How.P1}"/>
                    <TextBlock Style="{StaticResource Caption}" FontFamily="{StaticResource MonoFont}" Margin="0,12,0,0"
                               TextWrapping="Wrap" Text="{loc:Tr About.How.Tech}"/>
                </StackPanel>
            </Border>

            <!-- Meta / link -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Tr About.ProjectTitle}" Style="{StaticResource SectionLabel}"/>
                    <DockPanel Margin="0,10,0,0">
                        <TextBlock Text="{loc:Tr About.Repository}" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   FontFamily="{StaticResource MonoFont}" FontSize="12.5" Cursor="Hand"
                                   MouseLeftButtonUp="OnRepoClick">
                            <Run Text="github.com/rodrigogs/avell-sucks" Foreground="#FF22D3EE"/>
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="{loc:Tr About.Hardware}" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr About.HardwareValue}"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="{loc:Tr About.License}" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr About.LicenseValue}"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
