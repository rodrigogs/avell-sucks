<UserControl x:Class="AvellSucks.UI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left">

            <!-- Wordmark -->
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource NeonAxis}"
                                Effect="{StaticResource GlowMagenta}" VerticalAlignment="Center">
                            <TextBlock Text="&#xEC4A;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="#FF16060F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Avell" Style="{StaticResource H1}"/>
                                <TextBlock Text="Sucks" Style="{StaticResource H1}" Foreground="{StaticResource Magenta}"/>
                            </StackPanel>
                            <TextBlock Text="An unofficial control center for this machine — charged, precise, alive."
                                       Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- The story -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="WHY THIS EXISTS" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="A top-of-the-line Avell gaming laptop, bought in 2018. Years later the OEM &#8220;Gaming Center&#8221; — the app that owned the fan curve, the performance modes, the keyboard lighting, the whole thermal and power personality of the machine — was discontinued and abandoned."/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="The choice was to live with dead, unmaintained bloatware sitting between me and my own silicon, or replace it. This is the replacement. The name is not subtle on purpose."/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="AvellSucks does what the OEM app did — reads and writes the same Embedded Controller registers, switches the same Windows power plans — but modern, fast, and honest: it never lies about whether a hardware write actually landed."/>
                </StackPanel>
            </Border>

            <!-- How it works (brief) -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="HOW IT WORKS" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="Fan and power state live in Embedded Controller RAM, reached over a WMI ACPI method (AcpiTest_MULong). Every write goes through a safe pipeline — allowlist, read-back verify, rollback on mismatch, and an audit log — so a blocked or failed write reads as blocked or failed, never faked. Performance modes also switch the machine's dedicated Windows power schemes. Telemetry streams from the onboard sensors ~1 Hz, and changes made outside the app are reflected here within seconds."/>
                    <TextBlock Style="{StaticResource Caption}" FontFamily="{StaticResource MonoFont}" Margin="0,12,0,0"
                               Text="WPF · .NET 10 · reverse-engineered from the OEM app + live hardware probing"/>
                </StackPanel>
            </Border>

            <!-- Meta / link -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,16">
                <StackPanel>
                    <TextBlock Text="PROJECT" Style="{StaticResource SectionLabel}"/>
                    <DockPanel Margin="0,10,0,0">
                        <TextBlock Text="Repository" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   FontFamily="{StaticResource MonoFont}" FontSize="12.5" Cursor="Hand"
                                   MouseLeftButtonUp="OnRepoClick">
                            <Run Text="github.com/rodrigogs/avell-sucks" Foreground="#FF22D3EE"/>
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="Hardware" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Avell (RODRIGO-AVELL) · Intel + NVIDIA · Windows"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="License" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Personal, unofficial. Not affiliated with Avell."
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
