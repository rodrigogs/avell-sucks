<UserControl x:Class="AvellSucks.UI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left">

            <!-- Wordmark -->
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource NeonAxis}"
                                Effect="{StaticResource GlowMagenta}" VerticalAlignment="Center">
                            <TextBlock Text="&#xEC4A;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="#FF16060F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Avell" Style="{StaticResource H1}"/>
                                <TextBlock Text="Sucks" Style="{StaticResource H1}" Foreground="{StaticResource Magenta}"/>
                            </StackPanel>
                            <TextBlock Text="The control center this laptop should have shipped with."
                                       Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- The story -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="WHY THIS EXISTS" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="I bought a top-spec Avell laptop in 2018. The fan curve, the performance modes, the keyboard lighting, all of it lived inside Avell's Gaming Center app. Then Avell dropped it. No updates, no fixes, just abandonware that I still had to keep installed to control my own machine."/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="So I reverse engineered it and wrote my own. The name says how I feel about being left with dead software on hardware I paid a lot for."/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="It talks to the same hardware the old app did: the same EC registers, the same power plans. The difference is it's fast, it's mine, and it tells the truth. If a write to the hardware doesn't stick, it says so instead of pretending it worked."/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,14,0,0"
                               Text="The RGB tab is unfinished, and there's a reason. Around two years in, I opened the laptop to clean it and found the keyboard ribbon connector cracked and held together with a piece of tape. From the factory. The keyboard was already dying and there was no real way to fix it. Avell couldn't help, the warranty was gone, and it didn't matter that the fault was theirs to begin with. So the keyboard on this machine no longer works, which means the RGB lighting cannot be tested. The code is here, the hardware is not."/>
                </StackPanel>
            </Border>

            <!-- How it works (brief) -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="HOW IT WORKS" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="Fan and power settings live in the Embedded Controller's memory. The app reads and writes it through a WMI ACPI method (AcpiTest_MULong), the same path the old app used. Every write is checked against an allowlist, read back to confirm it landed, and rolled back if it didn't. All of it goes to an audit log. Performance modes also switch the machine's Windows power plan. Sensor readings refresh about once a second, and if you change something outside the app it shows up here within a couple of seconds."/>
                    <TextBlock Style="{StaticResource Caption}" FontFamily="{StaticResource MonoFont}" Margin="0,12,0,0"
                               Text="WPF, .NET 10. Reverse engineered from the OEM app plus a lot of live poking at the hardware."/>
                </StackPanel>
            </Border>

            <!-- Meta / link -->
            <Border Style="{StaticResource Panel}" Margin="0,16,0,16">
                <StackPanel>
                    <TextBlock Text="PROJECT" Style="{StaticResource SectionLabel}"/>
                    <DockPanel Margin="0,10,0,0">
                        <TextBlock Text="Repository" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   FontFamily="{StaticResource MonoFont}" FontSize="12.5" Cursor="Hand"
                                   MouseLeftButtonUp="OnRepoClick">
                            <Run Text="github.com/rodrigogs/avell-sucks" Foreground="#FF22D3EE"/>
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="Hardware" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Avell laptop, Intel and NVIDIA, Windows"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="License" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Personal, unofficial. Not affiliated with Avell."
                                   DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource Caption}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
