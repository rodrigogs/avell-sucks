<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         Typography — one UI sans + one mono for numerics.
         System fallbacks (Segoe UI Variable / Cascadia Code) so the
         build never depends on a bundled font asset. Swap FontFamily
         here to Inter / JetBrains Mono once packaged.
         ============================================================ -->

    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI, Inter, sans-serif</FontFamily>
    <FontFamily x:Key="UiFontDisplay">Segoe UI Variable Display, Segoe UI Semibold, Inter, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Cascadia Mono, JetBrains Mono, Consolas, monospace</FontFamily>

    <!-- Fixed px scale (product register, ratio ~1.2) -->
    <sys:Double x:Key="FsDisplay">34</sys:Double>
    <sys:Double x:Key="FsH1">24</sys:Double>
    <sys:Double x:Key="FsH2">19</sys:Double>
    <sys:Double x:Key="FsH3">16</sys:Double>
    <sys:Double x:Key="FsBody">14</sys:Double>
    <sys:Double x:Key="FsLabel">12.5</sys:Double>
    <sys:Double x:Key="FsCaption">11</sys:Double>

    <!-- ===== Named text styles ===== -->

    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FsH1}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FsH2}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
    </Style>

    <Style x:Key="H3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsH3}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
    </Style>

    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Section label: small-caps, wide tracking. Used as REAL structure, sparingly. -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Ink3}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsLabel}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink3}"/>
    </Style>

    <!-- Mono numerics — the instrument readout -->
    <Style x:Key="Mono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
    </Style>

    <!-- Big gauge value -->
    <Style x:Key="MonoDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsDisplay}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
    </Style>

</ResourceDictionary>
