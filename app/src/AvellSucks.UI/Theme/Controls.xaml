<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Shared control templates. Consistent vocabulary across tabs.
         Every interactive control has default/hover/focus/pressed/disabled.
         ============================================================ -->

    <!-- ===== Panel (surface container; sized to content, never a card grid) ===== -->
    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Compact panel — denser padding for data-dense dashboards -->
    <Style x:Key="PanelTight" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Padding" Value="13"/>
    </Style>

    <!-- ===== Focus ring (2px cyan) ===== -->
    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource RadiusSm}"
                            BorderBrush="{StaticResource Cyan}" BorderThickness="2"
                            Margin="-3" SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Secondary button — hairline border ===== -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverWash}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PressedWash}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Ink3}"/>
                            <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Segmented / toggle option (RadioButton styled as chip) ===== -->
    <Style x:Key="SegmentToggle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="Transparent"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverWash}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource MagentaTint}"/>
                            <Setter Property="Foreground" Value="{StaticResource Magenta}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Container for a row of SegmentToggles -->
    <Style x:Key="SegmentBar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface2}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- ===== Slider — neon fill + mono readout is added per-instance ===== -->
    <Style x:Key="NeonSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource Cyan}"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="6" CornerRadius="3" Background="{StaticResource Surface2}"
                                BorderBrush="{StaticResource Hairline}" BorderThickness="1"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="6" CornerRadius="3" Background="{StaticResource Cyan}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb" Width="18" Height="18" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse x:Name="e" Fill="{StaticResource Ink}" Width="18" Height="18">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TextBox (hex input, numeric) ===== -->
    <Style x:Key="MonoInput" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Cyan}"/>
        <Setter Property="Background" Value="{StaticResource Surface2}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ScrollBar — slim, dark ===== -->
    <Style x:Key="SlimScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="3" Background="{StaticResource Overlay}" Margin="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="10"/>
                <Setter Property="Width" Value="Auto"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== Nav rail item ===== -->
    <Style x:Key="NavItemStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!-- active neon marker -->
                        <Border x:Name="marker" Width="3" HorizontalAlignment="Left" CornerRadius="2"
                                Background="{StaticResource Magenta}" Opacity="0" Margin="0,7"/>
                        <Border x:Name="bd" Background="Transparent" CornerRadius="{StaticResource RadiusSm}"
                                Padding="12,10" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ico" Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="24" VerticalAlignment="Center"
                                           Foreground="{StaticResource Ink3}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverWash}"/>
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource MagentaTint}"/>
                            <Setter TargetName="marker" Property="Opacity" Value="1"/>
                            <Setter TargetName="ico" Property="Foreground" Value="{StaticResource Magenta}"/>
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Mode card (RadioButton as a selectable tile) ===== -->
    <!-- Used by the Performance tab. Content is set per-instance in code-behind
         (name + description + PL preview). Selected = cyan border + tint + glow. -->
    <Style x:Key="ModeCardStyle" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}" Padding="14,13"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface2}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Ink3}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource CyanTint}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource GlowCyan}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Disclosure toggle (Advanced expander header) ===== -->
    <Style x:Key="DisclosureToggle" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="{StaticResource RadiusSm}" Padding="4,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource Ink3}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                            <Setter TargetName="chev" Property="Foreground" Value="{StaticResource Cyan}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="chev" Property="Text" Value="&#xE70D;"/>
                            <Setter TargetName="chev" Property="Foreground" Value="{StaticResource Cyan}"/>
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Toggle switch (settings on/off) ===== -->
    <!-- A pill track + sliding knob. Off = hairline track / muted knob;
         On = magenta track + glow, knob slides right. -->
    <Style x:Key="NeonToggle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="13" Background="{StaticResource Surface2}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <!-- Knob position is driven by its Margin (left when off,
                             right when on); Margin targets cleanly from a trigger,
                             unlike a nested named RenderTransform (MC4111). -->
                        <Border x:Name="knob" Width="18" Height="18" CornerRadius="9"
                                HorizontalAlignment="Left" Margin="4,0,0,0"
                                Background="{StaticResource Ink3}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Ink3}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource Magenta}"/>
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Magenta}"/>
                            <Setter TargetName="track" Property="Effect" Value="{StaticResource GlowMagenta}"/>
                            <Setter TargetName="knob" Property="Background" Value="{StaticResource OnNeon}"/>
                            <Setter TargetName="knob" Property="Margin" Value="24,0,0,0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Sub-section label (inside a panel; smaller/quieter than SectionLabel) =====
         Groups related rows within one panel so a dense settings panel reads as
         structure, not a flat wall of toggles. Wide tracking, muted ink. -->
    <Style x:Key="SubSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
        <Setter Property="FontSize" Value="{StaticResource FsCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink3}"/>
    </Style>

    <!-- ===== Status strip =====
         A single-line state readout with a leading dot + glyph + text. The dot and
         glyph carry meaning WITH the text (never hue alone), so it stays legible and
         honest about the current state. Recolor Background/BorderBrush per state at
         the call site (Surface2 = neutral, DangerTint = live-exposed warning, etc). -->
    <Style x:Key="StatusStrip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface2}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ===== Danger row =====
         Wraps a settings row whose action is destructive/risky (remote hardware
         writes) so it reads as sharp-edged, not identical to a benign toggle.
         Danger tint fill + danger hairline; pair with a warning glyph in the row. -->
    <Style x:Key="DangerRow" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DangerTint}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Danger}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}"/>
        <Setter Property="Padding" Value="12,11"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ===== ComboBox (bind-address picker) — matches MonoInput surface vocabulary ===== -->
    <Style x:Key="NeonComboToggle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="{StaticResource Surface2}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                        <Grid>
                            <ContentPresenter Margin="10,7" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{StaticResource Ink3}" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeonCombo" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="tgl" Style="{StaticResource NeonComboToggle}"
                                      Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter x:Name="cp" Margin="10,0,28,0" VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False" PopupAnimation="Fade">
                            <Border Background="{StaticResource Overlay}" BorderBrush="{StaticResource Hairline}"
                                    BorderThickness="1" CornerRadius="{StaticResource RadiusSm}"
                                    MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240" Margin="0,4,0,0">
                                <ScrollViewer><ItemsPresenter/></ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeonComboItem" TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                            CornerRadius="{StaticResource RadiusSm}" Margin="3,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverWash}"/>
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource CyanTint}"/>
                            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default window-wide text color -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FsBody}"/>
        <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
    </Style>

</ResourceDictionary>
