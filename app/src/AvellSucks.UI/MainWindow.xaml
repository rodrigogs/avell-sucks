<Window x:Class="AvellSucks.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ctl="clr-namespace:AvellSucks.UI.Controls"
        xmlns:loc="clr-namespace:AvellSucks.UI.Localization"
        Title="AvellSucks" Height="720" Width="1280"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize" MinWidth="820" MinHeight="560"
        Background="{StaticResource AppBackdrop}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        FontFamily="{StaticResource UiFont}"
        StateChanged="OnWindowStateChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- System tray -->
        <tb:TaskbarIcon x:Name="Tray"
                        ToolTipText="AvellSucks"
                        IconSource="pack://application:,,,/app.ico"
                        TrayMouseDoubleClick="OnTrayDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Opened="OnTrayMenuOpened" Style="{StaticResource TrayContextMenu}">
                    <MenuItem Header="{loc:Tr Tray.Open}" Click="OnTrayOpen"/>
                    <Separator Style="{StaticResource TraySeparator}"/>
                    <MenuItem Header="{loc:Tr Tray.StartWithWindows}" x:Name="AutoStartItem"
                              IsCheckable="True" Click="OnToggleAutoStart"/>
                    <Separator Style="{StaticResource TraySeparator}"/>
                    <MenuItem Header="{loc:Tr Tray.Exit}" Click="OnTrayExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- ===== Nav rail ===== -->
        <Border Grid.Column="0" Width="212" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False" Margin="14,20">

                <!-- App mark -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,28">
                    <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource NeonAxis}"
                            Effect="{StaticResource GlowMagenta}">
                        <TextBlock Text="&#xEC4A;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="{StaticResource OnNeon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AVELL" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Ink}"
                                   LineHeight="14" LineStackingStrategy="BlockLineHeight"/>
                        <TextBlock Text="SUCKS" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Magenta}"
                                   LineHeight="14" LineStackingStrategy="BlockLineHeight"/>
                    </StackPanel>
                </StackPanel>

                <!-- Meta items pinned to the rail footer: Settings + About. Declared
                     with DockPanel.Dock=Bottom before the primary group so they hug
                     the bottom edge (About lowest), the way apps group secondary
                     navigation. Same GroupName so selection is exclusive across all. -->
                <StackPanel DockPanel.Dock="Bottom">
                    <RadioButton x:Name="NavSettings" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xE713;" Content="{loc:Tr Nav.Settings}" Checked="OnNavChecked"/>
                    <RadioButton x:Name="NavAbout" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xE946;" Content="{loc:Tr Nav.About}" Checked="OnNavChecked"/>
                </StackPanel>

                <!-- Primary nav -->
                <StackPanel DockPanel.Dock="Top" x:Name="NavItems">
                    <RadioButton x:Name="NavDashboard" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 IsChecked="True" Tag="&#xE80F;" Content="{loc:Tr Nav.Dashboard}"
                                 Checked="OnNavChecked"/>
                    <RadioButton x:Name="NavDevices" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xE950;" Content="{loc:Tr Nav.Devices}" Checked="OnNavChecked"/>
                    <RadioButton x:Name="NavFan" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xE9CA;" Content="{loc:Tr Nav.Fan}" Checked="OnNavChecked"/>
                    <RadioButton x:Name="NavRgb" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xE771;" Content="{loc:Tr Nav.Rgb}" Checked="OnNavChecked"/>
                    <RadioButton x:Name="NavPower" GroupName="nav" Style="{StaticResource NavItemStyle}"
                                 Tag="&#xEC4A;" Content="{loc:Tr Nav.Performance}" Checked="OnNavChecked"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Content area ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" Margin="24,16,24,8">
                <StackPanel>
                    <TextBlock x:Name="TabTitle" Text="Dashboard" Style="{StaticResource H1}"/>
                    <TextBlock x:Name="TabSubtitle" Text="Live telemetry from EC, WMI and onboard sensors"
                               Style="{StaticResource Body}" Foreground="{StaticResource Ink3}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Active tab host -->
            <ContentControl x:Name="TabHost" Grid.Row="1" Margin="24,6,24,16"/>

            <!-- Toast surface: spans the content rows, anchored bottom-right.
                 Write-result feedback lives here, not inline next to Apply. -->
            <ctl:ToastHost x:Name="Toast" Grid.Row="0" Grid.RowSpan="2"/>
        </Grid>
    </Grid>
</Window>
