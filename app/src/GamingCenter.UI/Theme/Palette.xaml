<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Gaming Center — Cyberpunk palette
         Deep violet-black base, magenta→cyan neon axis.
         Colors mirror DESIGN.md (OKLCH source of truth).
         ============================================================ -->

    <!-- Base / surfaces -->
    <Color x:Key="BgColor">#FF141018</Color>
    <Color x:Key="SurfaceColor">#FF1C1622</Color>
    <Color x:Key="Surface2Color">#FF251D2E</Color>
    <Color x:Key="OverlayColor">#FF2E2438</Color>
    <Color x:Key="HairlineColor">#803A2F47</Color>

    <!-- Ink -->
    <Color x:Key="InkColor">#FFF2EEF6</Color>
    <Color x:Key="Ink2Color">#FFC1B6CF</Color>
    <Color x:Key="Ink3Color">#FF948AA3</Color>

    <!-- Neon accent axis -->
    <Color x:Key="MagentaColor">#FFFF2E88</Color>
    <Color x:Key="CyanColor">#FF22D3EE</Color>
    <Color x:Key="VioletColor">#FFA855F7</Color>

    <!-- Semantic state -->
    <Color x:Key="OkColor">#FF34E5A0</Color>
    <Color x:Key="WarnColor">#FFF4C04A</Color>
    <Color x:Key="DangerColor">#FFF5484A</Color>

    <!-- Temperature ramp stops (cool → hot) -->
    <Color x:Key="Temp0Color">#FF22D3EE</Color>
    <Color x:Key="Temp1Color">#FF34E5A0</Color>
    <Color x:Key="Temp2Color">#FFF4C04A</Color>
    <Color x:Key="Temp3Color">#FFFF2E88</Color>
    <Color x:Key="Temp4Color">#FFF5484A</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="Overlay" Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="Hairline" Color="{StaticResource HairlineColor}"/>

    <SolidColorBrush x:Key="Ink" Color="{StaticResource InkColor}"/>
    <SolidColorBrush x:Key="Ink2" Color="{StaticResource Ink2Color}"/>
    <SolidColorBrush x:Key="Ink3" Color="{StaticResource Ink3Color}"/>

    <SolidColorBrush x:Key="Magenta" Color="{StaticResource MagentaColor}"/>
    <SolidColorBrush x:Key="Cyan" Color="{StaticResource CyanColor}"/>
    <SolidColorBrush x:Key="Violet" Color="{StaticResource VioletColor}"/>

    <SolidColorBrush x:Key="Ok" Color="{StaticResource OkColor}"/>
    <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}"/>

    <!-- Tinted fills for active/selected chips (neon at low alpha, never neon-on-neon) -->
    <SolidColorBrush x:Key="MagentaTint" Color="#26FF2E88"/>
    <SolidColorBrush x:Key="CyanTint" Color="#2622D3EE"/>
    <SolidColorBrush x:Key="VioletTint" Color="#26A855F7"/>
    <SolidColorBrush x:Key="OkTint" Color="#2634E5A0"/>
    <SolidColorBrush x:Key="WarnTint" Color="#26F4C04A"/>
    <SolidColorBrush x:Key="DangerTint" Color="#26F5484A"/>

    <!-- Hover/pressed wash -->
    <SolidColorBrush x:Key="HoverWash" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="PressedWash" Color="#0AFFFFFF"/>

    <!-- The reserved accent gradient: magenta → violet → cyan (135°) -->
    <LinearGradientBrush x:Key="NeonAxis" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource MagentaColor}" Offset="0"/>
        <GradientStop Color="{StaticResource VioletColor}" Offset="0.5"/>
        <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Horizontal variant for bars/headers -->
    <LinearGradientBrush x:Key="NeonAxisH" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource MagentaColor}" Offset="0"/>
        <GradientStop Color="{StaticResource VioletColor}" Offset="0.5"/>
        <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Temperature ramp as a horizontal gradient (for meter fills) -->
    <LinearGradientBrush x:Key="TempRamp" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Temp0Color}" Offset="0"/>
        <GradientStop Color="{StaticResource Temp1Color}" Offset="0.35"/>
        <GradientStop Color="{StaticResource Temp2Color}" Offset="0.6"/>
        <GradientStop Color="{StaticResource Temp3Color}" Offset="0.82"/>
        <GradientStop Color="{StaticResource Temp4Color}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Subtle top-lit panel sheen (very low alpha, adds depth without gradient-on-everything) -->
    <LinearGradientBrush x:Key="PanelSheen" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0AFFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="0.25"/>
    </LinearGradientBrush>

    <!-- App backdrop: near-flat violet-black with a faint magenta glow bleeding from top-left -->
    <RadialGradientBrush x:Key="AppBackdrop" GradientOrigin="0.15,0.0" Center="0.15,0.0" RadiusX="1.1" RadiusY="1.1">
        <GradientStop Color="#FF1B1424" Offset="0"/>
        <GradientStop Color="{StaticResource BgColor}" Offset="0.6"/>
    </RadialGradientBrush>

    <!-- ===== Reusable glow effects (use sparingly — perf) ===== -->
    <DropShadowEffect x:Key="GlowMagenta" Color="{StaticResource MagentaColor}" BlurRadius="22" ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="GlowCyan" Color="{StaticResource CyanColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowViolet" Color="{StaticResource VioletColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowOk" Color="{StaticResource OkColor}" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowDanger" Color="{StaticResource DangerColor}" BlurRadius="18" ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="GlowSoft" Color="#FF000000" BlurRadius="16" ShadowDepth="2" Opacity="0.45"/>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">10</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

</ResourceDictionary>
