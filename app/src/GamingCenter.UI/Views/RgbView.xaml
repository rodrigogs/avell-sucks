<UserControl x:Class="GamingCenter.UI.Views.RgbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:GamingCenter.UI.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Keyboard preview -->
            <Border Style="{StaticResource Panel}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="PREVIEW" Style="{StaticResource SectionLabel}"/>
                    <ctl:KeyboardPreview x:Name="Keyboard" Height="150" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Color -->
                <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="COLOR" Style="{StaticResource SectionLabel}"/>
                        <ctl:HsvPicker x:Name="Picker" Height="180" Margin="0,10,0,0"/>
                        <DockPanel Margin="0,12,0,0">
                            <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="{StaticResource RadiusSm}"
                                    x:Name="Swatch" Background="{StaticResource Magenta}" BorderBrush="{StaticResource Hairline}" BorderThickness="1"/>
                            <TextBox x:Name="HexInput" Style="{StaticResource MonoInput}" Margin="10,0,0,0"
                                     Text="#FF2E88" VerticalContentAlignment="Center"
                                     KeyDown="OnHexKey" LostFocus="OnHexCommit"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Effect + params -->
                <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="EFFECT" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource SegmentBar}" Margin="0,10,0,0">
                            <UniformGrid Columns="5" x:Name="EffectBar">
                                <RadioButton x:Name="FxStatic" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="Static" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxBreathing" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="Breathe" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxCycle" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="Cycle" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxWave" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="Wave" Checked="OnEffectChecked"/>
                                <RadioButton x:Name="FxRipple" GroupName="fx" Style="{StaticResource SegmentToggle}" Content="Ripple" Checked="OnEffectChecked"/>
                            </UniformGrid>
                        </Border>

                        <TextBlock Text="BRIGHTNESS" Style="{StaticResource FieldLabel}" Margin="2,18,0,0"/>
                        <Slider x:Name="BrightnessSlider" Style="{StaticResource NeonSlider}" Minimum="0" Maximum="100"
                                Value="100" Margin="0,6,0,0" ValueChanged="OnBrightnessChanged"/>

                        <TextBlock Text="SPEED" Style="{StaticResource FieldLabel}" Margin="2,14,0,0"/>
                        <Border Style="{StaticResource SegmentBar}" Margin="0,6,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" x:Name="SpeedBar">
                                <RadioButton x:Name="SpeedSlow" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="Slow" Checked="OnSpeedChecked"/>
                                <RadioButton x:Name="SpeedNormal" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="Normal" IsChecked="True" Checked="OnSpeedChecked"/>
                                <RadioButton x:Name="SpeedFast" GroupName="spd" Style="{StaticResource SegmentToggle}" Content="Fast" Checked="OnSpeedChecked"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Actions -->
            <DockPanel Margin="0,18,0,0">
                <ctl:StateBadge x:Name="Badge" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button x:Name="ApplyBtn" Content="Apply lighting" Style="{StaticResource PrimaryButton}"
                        DockPanel.Dock="Right" HorizontalAlignment="Right" Click="OnApply"/>
            </DockPanel>

            <Border x:Name="DeviceNotice" Style="{StaticResource Panel}" Margin="0,16,0,0"
                    Background="{StaticResource WarnTint}" BorderBrush="{StaticResource Warn}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="{StaticResource Warn}" VerticalAlignment="Center"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Ink}"
                               Text="RGB keyboard not detected (ITE HID 0x0489/0xCE40). Preview only — connect the device to actuate."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
